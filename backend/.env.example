# Shopify OAuth
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_SCOPES=read_products,write_products,read_content,write_content,read_analytics
SHOPIFY_REDIRECT_URI=http://localhost:3000/api/auth/shopify/callback

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/shopify_seo
DATABASE_POOL_SIZE=20

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# AI APIs
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
PERPLEXITY_API_KEY=your_perplexity_api_key

# SEO APIs
GOOGLE_SEARCH_CONSOLE_CLIENT_ID=your_gsc_client_id
GOOGLE_SEARCH_CONSOLE_CLIENT_SECRET=your_gsc_client_secret
GOOGLE_SEARCH_CONSOLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
DATAFORSEO_LOGIN=your_dataforseo_login
DATAFORSEO_PASSWORD=your_dataforseo_password
SEMRUSH_API_KEY=your_semrush_api_key
AHREFS_API_KEY=your_ahrefs_api_key

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
S3_BUCKET_NAME=shopify-seo-content
SQS_WEBHOOK_QUEUE_URL=your_sqs_queue_url

# Security (CRITICAL: Generate these with secure random methods)
# Generate ENCRYPTION_KEY with: openssl rand -hex 32
# Generate JWT_SECRET with: openssl rand -hex 64
ENCRYPTION_KEY=generate_with_openssl_rand_hex_32
JWT_SECRET=generate_with_openssl_rand_hex_64
SESSION_SECRET=generate_with_openssl_rand_hex_64

# Monitoring
DATADOG_API_KEY=your_datadog_api_key
SENTRY_DSN=your_sentry_dsn

# Application
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000
