# =====================================
# Shopify SEO Platform - Environment Variables
# =====================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# =====================================

# =====================================
# Application Configuration
# =====================================
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000

# =====================================
# Database Configuration
# =====================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shopify_seo
DATABASE_POOL_SIZE=20
DATABASE_CONNECTION_TIMEOUT=30000

# =====================================
# Redis Configuration
# =====================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_TTL=3600

# =====================================
# Security & Authentication
# =====================================
# Generate with: openssl rand -base64 48
JWT_SECRET=your-jwt-secret-64-characters-long-change-this-in-production

# Generate with: openssl rand -base64 32 | head -c 32
ENCRYPTION_KEY=your-encryption-key-32-chars-xx

# Session configuration
SESSION_SECRET=your-session-secret-change-this
SESSION_MAX_AGE=86400000

# CORS settings
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=true

# =====================================
# Shopify Configuration
# =====================================
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_SCOPES=read_products,write_products,read_content,write_content,read_script_tags,write_script_tags
SHOPIFY_APP_URL=https://your-app-url.com
SHOPIFY_API_VERSION=2026-01

# Shopify webhook configuration
SHOPIFY_WEBHOOK_SECRET=your_webhook_secret

# =====================================
# AWS Configuration
# =====================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# S3 buckets
S3_CONTENT_BUCKET=shopify-seo-content-dev
S3_IMAGES_BUCKET=shopify-seo-images-dev

# SQS queues
SQS_WEBHOOKS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT/shopify-webhooks-dev.fifo
SQS_CONTENT_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT/shopify-content-generation-dev

# CloudFront
CLOUDFRONT_DOMAIN=d123456789.cloudfront.net

# =====================================
# AI Service API Keys
# =====================================
# OpenAI (GPT models)
OPENAI_API_KEY=sk-...
OPENAI_ORGANIZATION_ID=org-...
OPENAI_MODEL=gpt-3.5-turbo

# Anthropic (Claude models)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Perplexity
PERPLEXITY_API_KEY=pplx-...

# =====================================
# SEO & Analytics APIs
# =====================================
# Google Search Console
GOOGLE_SEARCH_CONSOLE_CLIENT_ID=your_gsc_client_id
GOOGLE_SEARCH_CONSOLE_CLIENT_SECRET=your_gsc_client_secret
GOOGLE_SEARCH_CONSOLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# DataForSEO
DATAFORSEO_LOGIN=your_dataforseo_login
DATAFORSEO_PASSWORD=your_dataforseo_password

# SEMrush
SEMRUSH_API_KEY=your_semrush_api_key

# Ahrefs
AHREFS_API_KEY=your_ahrefs_api_key

# =====================================
# Monitoring & Error Tracking
# =====================================
# DataDog
DATADOG_API_KEY=your_datadog_api_key
DATADOG_APP_KEY=your_datadog_app_key
DATADOG_SITE=datadoghq.com
DD_ENV=development
DD_SERVICE=shopify-seo-platform
DD_VERSION=1.0.0
DD_LOGS_ENABLED=true
DD_APM_ENABLED=true

# Sentry
SENTRY_DSN=https://...@sentry.io/...
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# =====================================
# Email Configuration
# =====================================
# SendGrid
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@shopify-seo.com
SENDGRID_FROM_NAME=Shopify SEO Platform

# AWS SES (alternative to SendGrid)
SES_FROM_EMAIL=noreply@shopify-seo.com
SES_CONFIGURATION_SET=shopify-seo-emails

# =====================================
# Rate Limiting
# =====================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false

# =====================================
# Background Jobs & Queues
# =====================================
# BullMQ configuration
BULL_REDIS_HOST=localhost
BULL_REDIS_PORT=6379
BULL_REDIS_PASSWORD=

# Job concurrency
WEBHOOK_QUEUE_CONCURRENCY=5
CONTENT_GENERATION_QUEUE_CONCURRENCY=3

# =====================================
# Feature Flags
# =====================================
FEATURE_AI_CONTENT_GENERATION=true
FEATURE_BULK_OPERATIONS=true
FEATURE_ANALYTICS_DASHBOARD=true
FEATURE_GOOGLE_SEARCH_CONSOLE=false
FEATURE_COMPETITOR_ANALYSIS=false

# =====================================
# Logging Configuration
# =====================================
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_COLORIZE=true

# =====================================
# Development Tools
# =====================================
# Prisma Studio
PRISMA_STUDIO_PORT=5555

# Debug mode
DEBUG=app:*

# =====================================
# Testing Configuration (for CI/CD)
# =====================================
# CI environment variables
CI=false
SKIP_E2E_TESTS=false
SKIP_INTEGRATION_TESTS=false

# Test database
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shopify_seo_test

# =====================================
# Production-Only Settings
# =====================================
# (Only set these in production environment)

# Force HTTPS
FORCE_HTTPS=false

# Trust proxy (for ALB)
TRUST_PROXY=false

# Helmet security headers
HELMET_ENABLED=true

# Request timeout (ms)
REQUEST_TIMEOUT=30000

# Body size limits
MAX_REQUEST_BODY_SIZE=10mb

# =====================================
# Optional Services
# =====================================
# Stripe (for billing)
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# Intercom (for support)
INTERCOM_ACCESS_TOKEN=

# Mixpanel (for analytics)
MIXPANEL_TOKEN=

# =====================================
# NOTES
# =====================================
# 1. Generate secure secrets using: openssl rand -base64 32
# 2. Never commit this file with real values
# 3. Use AWS Secrets Manager for production
# 4. Rotate secrets regularly (every 90 days)
# 5. Use different values for dev/staging/production
